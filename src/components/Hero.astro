---
import logoSvg from "../assets/Logo.svg?raw";

const {
  title = "Stay Observant",
  primaryCtaText = "View work",
  primaryCtaHref = "#work",
  secondaryCtaText = "Contact",
  secondaryCtaHref = "#contact",
} = Astro.props;
---

<section class="relative w-full overflow-hidden">
  <!-- PARALLAX BACKGROUND -->
  <img
    src="/hero-bg.avif"
    alt=""
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 h-full w-full scale-110 object-cover will-change-transform"
    data-parallax
    style="transform: translate3d(0,0,0); filter: saturate(0.75) brightness(0.75);"
  />

  <!-- DARK OVERLAY -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/55 to-black/75"
  >
  </div>

  <!-- HERO CONTENT -->
  <div class="relative z-10 mx-auto max-w-6xl px-6 py-14 md:py-16">
    <!-- Logo + Title Block -->
    <div class="flex justify-center">
      <div class="flex items-center gap-8">
        <div
          class="h-32 w-32 shrink-0 text-white md:h-36 md:w-36 [&>svg]:h-full [&>svg]:w-full"
          set:html={logoSvg}
        />

        <div class="text-left">
          <h1
            class="text-2xl font-bold uppercase leading-none tracking-[0.06em] text-white md:text-5xl"
          >
            {title}
          </h1>

          <div
            class="mt-3 flex w-full items-center justify-between text-[10px] font-semibold uppercase tracking-[0.14em] text-white/85 md:text-xs"
          >
            <span>Graphic Design</span>
            <span class="text-white/35">•</span>
            <span>UI/UX</span>
            <span class="text-white/35">•</span>
            <span>Industrial Design</span>
          </div>
        </div>
      </div>
    </div>

    <!-- COUNTERS (CENTERED) -->
    <div class="mt-6 flex justify-center">
      <div class="w-full max-w-2xl">
        <!-- Divider -->
        <div class="mx-auto mb-7 h-px w-80 bg-white/25"></div>

        <div class="grid grid-cols-1 gap-8 text-center sm:grid-cols-3">
          <!-- Years -->
          <div class="stat" data-reveal style="transition-delay: 0ms;">
            <div class="text-3xl font-extrabold text-white leading-none">
              <span data-count data-to="18" data-suffix="+">0</span>
            </div>
            <div
              class="mt-2 text-[10px] font-semibold uppercase tracking-[0.16em] text-white/60"
            >
              Years Experience
            </div>
          </div>

          <!-- Clients -->
          <div class="stat" data-reveal style="transition-delay: 90ms;">
            <div class="text-3xl font-extrabold text-white leading-none">
              <span data-count data-to="42" data-suffix="+">0</span>
            </div>
            <div
              class="mt-2 text-[10px] font-semibold uppercase tracking-[0.16em] text-white/60"
            >
              Clients
            </div>
          </div>

          <!-- Projects -->
          <div class="stat" data-reveal style="transition-delay: 180ms;">
            <div class="text-3xl font-extrabold text-white leading-none">
              <span data-count data-to="120" data-suffix="+">0</span>
            </div>
            <div
              class="mt-2 text-[10px] font-semibold uppercase tracking-[0.16em] text-white/60"
            >
              Projects Completed
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA BUTTONS -->
    <div class="mt-6 flex flex-col items-center gap-4">
      <div class="grid w-full max-w-xl grid-cols-1 gap-3 sm:grid-cols-2">
        <a href={primaryCtaHref} class="hero-btn w-full">
          <span class="hero-btn__label">{primaryCtaText}</span>
          <span class="hero-btn__smoke" aria-hidden="true"></span>
          <span class="hero-btn__grain" aria-hidden="true"></span>
        </a>

        <a href={secondaryCtaHref} class="hero-btn w-full">
          <span class="hero-btn__label">{secondaryCtaText}</span>
          <span class="hero-btn__smoke" aria-hidden="true"></span>
          <span class="hero-btn__grain" aria-hidden="true"></span>
        </a>
      </div>

      <a
        href="/Brian-Rodriguez-CV.pdf"
        target="_blank"
        rel="noopener"
        class="text-xs font-semibold uppercase tracking-wide text-white/70 transition hover:text-white"
      >
        Download CV
      </a>
    </div>
  </div>

  <!-- SCRIPT -->
  <script>
    (() => {
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

      const init = () => {
        // Parallax
        if (!prefersReduced) {
          const bg = document.querySelector("[data-parallax]");
          if (bg) {
            const speed = 0.22;
            const tick = () => {
              bg.style.transform = `translate3d(0, ${window.scrollY * speed}px, 0)`;
              requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          }
        }

        // Reveal + Count on view
        const stats = document.querySelectorAll("[data-reveal]");
        const counters = document.querySelectorAll("[data-count]");

        const animateCount = (el, to, durationMs) => {
          const suffix = el.getAttribute("data-suffix") || "";
          const start = performance.now();

          const tick = (now) => {
            const t = Math.min(1, (now - start) / durationMs);
            el.textContent = Math.round(to * easeOutCubic(t)) + suffix;
            if (t < 1) requestAnimationFrame(tick);
          };

          requestAnimationFrame(tick);
        };

        // initial state (fade up)
        stats.forEach((s) => s.classList.add("reveal-init"));

        if (prefersReduced) {
          stats.forEach((s) => s.classList.add("reveal-in"));
          counters.forEach((el) => {
            const to = Number(el.getAttribute("data-to") || "0");
            const suffix = el.getAttribute("data-suffix") || "";
            el.textContent = to + suffix;
          });
          return;
        }

        let started = false;

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              // reveal
              stats.forEach((s) => s.classList.add("reveal-in"));

              // start counts once
              if (!started) {
                started = true;
                counters.forEach((el, i) => {
                  const to = Number(el.getAttribute("data-to") || "0");
                  // stagger the numbers slightly
                  setTimeout(() => animateCount(el, to, 1300), i * 110);
                });
              }

              io.disconnect();
            });
          },
          { threshold: 0.25 }
        );

        // observe the first stat block as the trigger
        const trigger = document.querySelector(".stat");
        if (trigger) io.observe(trigger);
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init, { once: true });
      } else {
        init();
      }
    })();
  </script>

  <!-- STYLES -->
  <style>
    /* reveal */
    .reveal-init {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 700ms ease,
        transform 700ms ease;
    }
    .reveal-in {
      opacity: 1;
      transform: translateY(0);
    }
    .stat--alt {
      opacity: 0.9;
    }

    /* Buttons: glass + center-bloom smoke fill + grain */
    .hero-btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 24px;
      border-radius: 14px;
      font-weight: 700;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.4);
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition:
        transform 420ms ease,
        border-color 420ms ease,
        background 420ms ease;
    }

    .hero-btn:hover {
      border-color: rgba(255, 255, 255, 0.72);
      background: rgba(255, 255, 255, 0.12);
      transform: translateY(-2px);
    }

    .hero-btn__label {
      position: relative;
      z-index: 5;
      letter-spacing: 0.02em;
      color: rgba(255, 255, 255, 0.92);
      transition: color 1200ms cubic-bezier(0.22, 0.8, 0.2, 1);
    }

    .hero-btn:hover .hero-btn__label {
      color: #0b0b0f;
    }

    .hero-btn__smoke {
      position: absolute;
      inset: -60%;
      z-index: 2;
      pointer-events: none;

      opacity: 0;
      transform: translate3d(0, 0, 0) scale(0.32);
      filter: blur(26px);

      background:
        radial-gradient(
          circle at 50% 50%,
          rgba(255, 255, 255, 1) 0%,
          rgba(255, 255, 255, 0) 58%
        ),
        radial-gradient(
          circle at 46% 62%,
          rgba(255, 255, 255, 0.88) 0%,
          rgba(255, 255, 255, 0) 62%
        ),
        radial-gradient(
          circle at 63% 44%,
          rgba(255, 255, 255, 0.78) 0%,
          rgba(255, 255, 255, 0) 64%
        ),
        radial-gradient(
          circle at 52% 72%,
          rgba(255, 255, 255, 0.68) 0%,
          rgba(255, 255, 255, 0) 66%
        );

      transition:
        opacity 1200ms cubic-bezier(0.22, 0.8, 0.2, 1),
        transform 2600ms cubic-bezier(0.22, 0.8, 0.2, 1),
        filter 2600ms cubic-bezier(0.22, 0.8, 0.2, 1);
    }

    .hero-btn:hover .hero-btn__smoke {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1.25);
      filter: blur(14px);
    }

    .hero-btn__grain {
      position: absolute;
      inset: -20%;
      opacity: 0;
      z-index: 4;
      pointer-events: none;
      mix-blend-mode: overlay;
      filter: contrast(120%) brightness(110%);
      transition: opacity 1200ms cubic-bezier(0.22, 0.8, 0.2, 1);

      background:
        repeating-linear-gradient(
          0deg,
          rgba(255, 255, 255, 0.06) 0px,
          rgba(255, 255, 255, 0.06) 1px,
          rgba(0, 0, 0, 0.06) 2px,
          rgba(0, 0, 0, 0.06) 3px
        ),
        repeating-linear-gradient(
          90deg,
          rgba(255, 255, 255, 0.05) 0px,
          rgba(255, 255, 255, 0.05) 1px,
          rgba(0, 0, 0, 0.05) 2px,
          rgba(0, 0, 0, 0.05) 3px
        );

      transform: translate3d(0, 0, 0);
      animation: grainJitter 1800ms steps(6) infinite;
    }

    .hero-btn:hover .hero-btn__grain {
      opacity: 0.2;
    }

    @keyframes grainJitter {
      0% {
        transform: translate3d(0, 0, 0);
      }
      20% {
        transform: translate3d(-2%, 1%, 0);
      }
      40% {
        transform: translate3d(2%, -1%, 0);
      }
      60% {
        transform: translate3d(-1%, -2%, 0);
      }
      80% {
        transform: translate3d(1%, 2%, 0);
      }
      100% {
        transform: translate3d(0, 0, 0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-btn,
      .hero-btn__label,
      .hero-btn__smoke,
      .hero-btn__grain,
      .reveal-init {
        transition: none;
        animation: none;
      }
    }
  </style>
</section>
