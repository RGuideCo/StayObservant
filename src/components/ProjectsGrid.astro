---
import { projects } from "../data/projects.js";

const uniqueTags = Array.from(
  new Set(projects.flatMap((p) => p.tags || []).filter(Boolean))
).sort((a, b) => a.localeCompare(b));
---

<section id="work" class="section-pad">
  <div class="container-page">
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3" data-project-filters>
      <button
        type="button"
        class="project-filter-btn is-active"
        data-filter="all"
      >
        All
      </button>
      {uniqueTags.map((tag) => (
        <button
          type="button"
          class="project-filter-btn"
          data-filter={tag.toLowerCase()}
        >
          {tag}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="mt-9 grid gap-x-5 gap-y-10 md:grid-cols-2 lg:grid-cols-12">
      {projects.map((p, index) => (
        <a
          href={`/work/${p.slug}`}
          data-project-card
          data-project-tags={(p.tags || []).map((t) => t.toLowerCase()).join("|")}
          class={`card project-card group relative block overflow-hidden rounded-[0.85rem] bg-black shadow-sm transition-all duration-300 ease-out hover:shadow-2xl ${
            index === 0
              ? "h-[560px] md:col-span-2 lg:col-span-7"
              : index === 1
                ? "h-[560px] lg:col-span-5"
                : "h-[430px] lg:col-span-4"
          }`}
        >
          <!-- Rounded clip layer (prevents hard corners) -->
          <div class="clip absolute inset-0 overflow-hidden rounded-[0.85rem]">

            <!-- Full image -->
            <img
              src={p.image}
              alt={p.title}
              loading={index < 2 ? "eager" : "lazy"}
              fetchpriority={index < 2 ? "high" : "auto"}
              decoding="async"
class={`absolute inset-0 h-full w-full object-cover ${index === 0 ? "object-right" : "object-center"} transition-transform duration-700 ease-out group-hover:scale-[1.04]`}            />

            <!-- Glass panel -->
            <div
              class="panel absolute inset-x-0 bottom-0 overflow-hidden border-t border-white/70 bg-white/80 backdrop-blur-3xl supports-[backdrop-filter]:bg-white/70"
            >
              <!-- Title strip -->
              <div class="title-row flex items-center px-6">
                <div>
                  <h3 class="text-base font-semibold tracking-[-0.02em] text-gray-950 md:text-lg">
                    {p.title}
                  </h3>
                </div>
              </div>

              <!-- Reveal content -->
              <div class="reveal px-6 pb-4">
                <dl class="project-card-meta">
                  <div>
                    <dt>Role</dt>
                    <dd>{p.role ?? "Design"}</dd>
                  </div>
                  <div>
                    <dt>Medium</dt>
                    <dd>{p.medium ?? p.tags?.[0] ?? "Case Study"}</dd>
                  </div>
                </dl>
                <p class="text-sm leading-snug text-gray-700">
                  {p.description}
                </p>

                <ul class="mt-3 flex flex-wrap gap-1.5">
                  {p.tags.map((t) => (
                    <li class="rounded-full bg-white px-2.5 py-0.5 text-[11px] font-semibold text-gray-800">
                      {t}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <style>
    /* Collapsed strip */
    .panel {
      height: 76px;
      transition: height 420ms cubic-bezier(.22,.8,.2,1);
    }

    .title-row {
      height: 76px;
    }

    /* Expanded to ~1/3 card */
    .card:hover .panel,
    .card:focus-visible .panel {
      height: 218px;
    }

    /* Reveal animation */
    .reveal {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 260ms ease,
        transform 420ms cubic-bezier(.22,.8,.2,1);
    }

    .card:hover .reveal,
    .card:focus-visible .reveal {
      opacity: 1;
      transform: translateY(0);
      transition-delay: 60ms;
    }

    /* Prevent corner glitching */
    .clip {
      transform: translateZ(0);
      -webkit-mask-image: -webkit-radial-gradient(white, black);
    }

    .project-card-meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      margin: 0 0 0.8rem;
      padding: 0 0 0.8rem;
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .project-card-meta dt {
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: rgba(63, 63, 70, 0.62);
    }

    .project-card-meta dd {
      margin-top: 0.2rem;
      font-size: 0.79rem;
      font-weight: 650;
      color: #18181b;
    }

    .project-filter-btn {
      position: relative;
      padding: 0.25rem 0;
      border: 0;
      background: transparent;
      color: #52525b;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: color 180ms ease;
    }

    .project-filter-btn::after {
      content: "";
      position: absolute;
      right: 0;
      bottom: -0.18rem;
      left: 0;
      height: 1px;
      background: currentColor;
      transform: scaleX(0);
      transform-origin: center;
      transition: transform 180ms ease;
    }

    .project-filter-btn:hover {
      color: #18181b;
    }

    .project-filter-btn.is-active {
      color: #18181b;
    }

    .project-filter-btn.is-active::after {
      transform: scaleX(1);
    }
  </style>

  <script>
    (() => {
      const init = () => {
        const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
        const projectCards = Array.from(document.querySelectorAll("[data-project-card]"));
        if (filterButtons.length && projectCards.length) {
          const applyFilter = (filter) => {
            filterButtons.forEach((btn) => {
              btn.classList.toggle("is-active", btn.getAttribute("data-filter") === filter);
            });

            projectCards.forEach((card) => {
              const tags = card.getAttribute("data-project-tags") || "";
              const show = filter === "all" || tags.split("|").includes(filter);
              card.classList.toggle("hidden", !show);
            });
          };

          filterButtons.forEach((button) => {
            button.addEventListener("click", () => {
              applyFilter(button.getAttribute("data-filter") || "all");
            });
          });

          applyFilter("all");
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init, { once: true });
      } else {
        init();
      }
    })();
  </script>
</section>
