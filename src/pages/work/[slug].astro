---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;
const projects = await getCollection("projects");
const entry = projects.find((p) => p.slug === slug);

if (!entry) {
  return new Response("Not found", { status: 404 });
}

const { Content } = await entry.render();
const project = entry.data;
---

<Layout title={project.title}>
  <!-- HERO -->
  <header class="relative w-full overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${project.hero ?? project.cover}');`}
      aria-hidden="true"
    >
    </div>

    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10">
      <div class="container-page py-20">
        <a
          href="/#work"
          class="inline-flex items-center gap-2 text-sm font-semibold text-white/90 underline decoration-white/40 underline-offset-4 hover:text-white transition"
        >
          ← Back to work
        </a>

        <h1 class="project-hero-title mt-8 text-5xl font-semibold tracking-[0.02em] text-white md:text-6xl">
          {project.title}
        </h1>

        <p class="mt-6 max-w-2xl text-lg text-white/85">
          {project.description}
        </p>

        {
          project.tags?.length ? (
            <ul class="mt-8 flex flex-wrap gap-3">
              {project.tags.map((tag) => (
                <li class="rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-semibold text-white backdrop-blur-sm">
                  {tag}
                </li>
              ))}
            </ul>
          ) : null
        }
      </div>
    </div>
  </header>

  <!-- BODY -->
  <div class="bg-[#F6F3ED] text-black">
    <main class="container-page pt-14 pb-20 md:pt-16 md:pb-24">
      <section class="project-meta-strip" aria-label="Project metadata">
        {
          project.role ? (
            <div class="project-meta-item">
              <span class="project-meta-label">Role</span>
              <p class="project-meta-value">{project.role}</p>
            </div>
          ) : null
        }
        {
          project.tools?.length ? (
            <div class="project-meta-item">
              <span class="project-meta-label">Tools</span>
              <p class="project-meta-value">{project.tools.join(" · ")}</p>
            </div>
          ) : null
        }
        {
          project.deliverables?.length ? (
            <div class="project-meta-item">
              <span class="project-meta-label">Deliverables</span>
              <p class="project-meta-value">{project.deliverables.join(" · ")}</p>
            </div>
          ) : null
        }
      </section>

      <div class="project-shell">
        <article class="project-content">
          <Content />
        </article>

        <aside class="project-toc" aria-label="On this page">
          <p class="project-toc-title">On This Page</p>
          <nav>
            <ul class="project-toc-list" data-project-toc></ul>
          </nav>
        </aside>
      </div>
    </main>
  </div>
</Layout>

<style is:global>
  /* ===============================
     Layout Width (2/3 centered)
  =============================== */

  .project-content {
    max-width: 100%;
    margin: 0 auto;
    color: #18181b;
  }

  .project-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.045em;
  }

  .project-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 980px) minmax(0, 1fr);
    align-items: start;
    gap: 0;
  }

  .project-shell .project-content {
    grid-column: 2;
    grid-row: 1;
  }

  .project-shell .project-toc {
    grid-column: 1;
    grid-row: 1;
    justify-self: end;
    width: 220px;
    margin-right: 1.6rem;
  }

  .project-meta-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin-bottom: 1.4rem;
  }

  .project-meta-item {
    padding: 0.7rem 0.8rem;
    border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.58);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .project-meta-label {
    display: block;
    font-size: 0.66rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .project-meta-value {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: #27272a;
  }

  .project-toc {
    position: sticky;
    top: 1.3rem;
    padding: 0.2rem 0 0.2rem 0.9rem;
    border-radius: 0;
    background: transparent;
    border-left: 1px solid rgba(0, 0, 0, 0.16);
  }

  .project-toc-title {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .project-toc-list {
    list-style: none;
    margin: 0.8rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }

  .project-toc-list li {
    margin: 0;
    padding: 0;
  }

  .project-toc-list a {
    position: relative;
    display: block;
    padding: 0.14rem 0 0.14rem 0.4rem;
    text-decoration: none;
    color: #3f3f46;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .project-toc-list .toc-section > a {
    font-weight: 600;
  }

  .project-toc-sublist {
    list-style: none;
    margin: 0.28rem 0 0 0;
    padding: 0 0 0 0.64rem;
    display: grid;
    gap: 0.16rem;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-3px);
    transition:
      max-height 420ms cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 280ms ease,
      transform 320ms ease;
  }

  .project-toc-list .toc-section.is-expanded .project-toc-sublist {
    opacity: 1;
    transform: translateY(0);
  }

  .project-toc-sublist a {
    color: #71717a;
    font-size: 0.78rem;
  }

  .project-toc-list a:hover,
  .project-toc-list a.is-active {
    color: #09090b;
  }

  .project-toc-list a.is-active::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    bottom: 0.35rem;
    left: -0.92rem;
    width: 2px;
    border-radius: 999px;
    background: #d7262d;
  }

  /* ===============================
     Clean vertical rhythm
  =============================== */

  /* spacing between ALL top-level markdown blocks */
  .project-content > * + * {
    margin-top: 2rem;
  }

  /* Base body copy */
  .project-content p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #3f3f46;
  }

  .project-content a {
    color: #18181b;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(0, 0, 0, 0.25);
    transition: text-decoration-color 180ms ease;
  }

  .project-content a:hover {
    text-decoration-color: rgba(0, 0, 0, 0.6);
  }

  /* Section headers */
  .project-content :is(h2, h3) {
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: #09090b;
  }

  .project-content h2 {
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2vw, 2.05rem);
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .project-content h3 {
    font-size: clamp(1.02rem, 1.25vw, 1.14rem);
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  /* Dividers before major sections for a cleaner scan */
  .project-content > h2:not(:first-child),
  .project-content > h3:not(:first-child) {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0, 0, 0, 0.14);
  }

  .project-content :where(ul, ol) {
    margin: 0;
    padding-left: 1.25rem;
    color: #3f3f46;
    line-height: 1.65;
  }

  .project-content ul {
    list-style: disc;
  }

  .project-content ol {
    list-style: decimal;
  }

  .project-content :where(li + li) {
    margin-top: 0.5rem;
  }

  .project-content hr {
    display: none;
  }

  .project-content blockquote {
    margin: 0;
    padding: 1.25rem 1.25rem 1.35rem;
    border: 0;
    border-radius: 0.875rem;
    background: #d7262d;
    color: #fff;
  }

  .project-content blockquote p {
    color: #fff;
  }

  .project-content blockquote strong {
    color: #fff;
  }

  .project-content blockquote ul {
    position: relative;
    margin-top: 0.5rem;
    list-style: none;
    padding-left: 0;
    border-left: 0;
  }

  .project-content blockquote ul::before {
    content: "";
    position: absolute;
    top: 0.25rem;
    bottom: 0.25rem;
    left: 0.36rem;
    width: 2px;
    background: rgba(255, 255, 255, 0.45);
  }

  .project-content blockquote li {
    position: relative;
    margin-top: 1rem;
    padding-left: 1.35rem;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.6;
  }

  .project-content blockquote li::before {
    content: "";
    position: absolute;
    top: 0.4rem;
    left: 0;
    width: 0.74rem;
    height: 0.74rem;
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.16);
  }

  .project-content blockquote li strong {
    display: block;
    margin-bottom: 0.15rem;
    color: #fff;
  }

  .project-content blockquote li a {
    display: inline-flex;
    align-items: center;
    margin: 0.2rem 0.45rem 0.2rem 0;
    padding: 0.34rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    color: #fff;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: background-color 180ms ease, color 180ms ease;
  }

  .project-content blockquote li a:hover {
    background: #fff;
    color: #b1131a;
  }

  .project-content blockquote .timeline-group {
    display: inline-block;
    margin: 0.35rem 0 0.2rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .project-content blockquote .timeline-group--altruism {
    color: #fff;
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.42);
  }

  .project-content blockquote .timeline-group--farm {
    color: #fff7e8;
    background: rgba(255, 198, 120, 0.2);
    border: 1px solid rgba(255, 212, 156, 0.62);
  }

  .project-content blockquote .timeline-link-row {
    display: block;
  }

  .project-content blockquote .timeline-link-row--farm a {
    border-color: rgba(255, 214, 161, 0.9);
    color: #fff0db;
    background: rgba(132, 72, 18, 0.34);
  }

  .project-content blockquote .timeline-link-row--farm a:hover {
    background: #ffd7a6;
    color: #7c3f00;
    border-color: #ffd7a6;
  }

  /* ===============================
     Image Handling (THE FIX)
  =============================== */

  /* All images behave like blocks */
  .project-content img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    border: 0;
  }

  /* If image is wrapped in <p>, give it vertical space */
  .project-content p > img,
  .project-content p > .project-image-frame {
    margin: 2.5rem 0;
  }

  /* If markdown outputs consecutive images in SAME paragraph */
  .project-content img + img {
    margin-top: 2.5rem;
  }

  .project-content .project-image-frame {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 0.875rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .project-content .project-image-bar {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    align-items: center;
    min-height: 34px;
    padding: 0.4rem 0.75rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.96);
    background: rgba(10, 10, 12, 0.72);
    backdrop-filter: blur(3px);
    transform: translateY(105%);
    transition: transform 220ms ease;
    pointer-events: none;
  }

  @media (hover: hover) {
    .project-content .project-image-frame:hover .project-image-bar,
    .project-content .project-image-frame:focus-within .project-image-bar {
      transform: translateY(0);
    }
  }

  /* If figures ever appear */
  .project-content figure {
    margin: 2.5rem 0;
  }

  .project-content figure + figure {
    margin-top: 2.5rem;
  }

  /* Joy Machine concept split section */
  .project-content .concept-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .project-content .concept-slider-main {
    position: relative;
    min-height: 320px;
  }

  .project-content .concept-slide {
    display: none;
  }

  .project-content .concept-slide.is-active {
    display: block;
  }

  .project-content .concept-slide .project-image-frame {
    margin: 0;
  }

  .project-content .concept-slide .project-image-bar {
    transform: translateY(0);
  }

  .project-content .concept-thumbs {
    margin-top: 0.75rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-content .concept-thumbs button {
    width: 56px;
    height: 56px;
    border: 1px solid rgba(0, 0, 0, 0.14);
    border-radius: 999px;
    overflow: hidden;
    background: #fff;
    padding: 0;
    cursor: pointer;
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .project-content .concept-thumbs button:hover {
    border-color: rgba(0, 0, 0, 0.45);
    transform: translateY(-1px);
  }

  .project-content .concept-thumbs button.is-active {
    border-color: rgba(0, 0, 0, 0.65);
  }

  .project-content .concept-thumbs img {
    margin: 0;
    border: 0;
    border-radius: 999px;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-content .concept-copy {
    border-left: 1px solid rgba(0, 0, 0, 0.14);
    padding-left: 1rem;
    align-self: center;
  }

  .project-content .concept-copy > h3 {
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    text-transform: none;
  }

  .project-content .concept-copy ul {
    margin-top: 0.75rem;
    padding-left: 1rem;
    list-style: disc;
  }

  .project-content .concept-copy li {
    margin-top: 0.9rem;
    color: #3f3f46;
    line-height: 1.65;
  }

  .project-content .concept-copy li strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #09090b;
  }

  .project-content .concept-copy h3 + p {
    margin-top: 0.6rem;
  }

  .project-content .concept-copy p + h3 {
    margin-top: 1.2rem;
  }

  .project-content .model-horizontal {
    position: relative;
    overflow: hidden;
    padding: 0.55rem 0.9rem 0.65rem;
    border-radius: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(244, 240, 233, 0.85));
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .project-content .model-horizontal .filmstrip-track {
    display: flex;
    gap: 0;
    width: max-content;
    will-change: transform;
    animation: filmstrip-scroll var(--filmstrip-duration, 28s) linear infinite;
  }

  .project-content .model-horizontal::before,
  .project-content .model-horizontal::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 64px;
    z-index: 2;
    pointer-events: none;
  }

  .project-content .model-horizontal::before {
    left: 0;
    background: linear-gradient(to right, #f6f3ed 5%, rgba(246, 243, 237, 0));
  }

  .project-content .model-horizontal::after {
    right: 0;
    background: linear-gradient(to left, #f6f3ed 5%, rgba(246, 243, 237, 0));
  }

  .project-content .model-horizontal:hover .filmstrip-track,
  .project-content .model-horizontal:focus-within .filmstrip-track {
    animation-play-state: paused;
  }

  .project-content .model-horizontal .project-image-frame {
    flex: 0 0 min(56vw, 360px);
    max-width: 360px;
    min-width: 260px;
    margin: 0;
    cursor: pointer;
    border-radius: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.24);
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    transition: transform 180ms ease, box-shadow 180ms ease, z-index 180ms ease;
    transform-origin: center center;
  }

  .project-content .model-horizontal .project-image-frame img {
    width: 100%;
    height: 178px;
    object-fit: cover;
    transition: none;
  }

  .project-content .model-horizontal .project-image-frame:hover {
    transform: scale(1.045);
    z-index: 3;
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.24);
  }

  .project-content .model-slideshow {
    margin-top: 0;
    position: relative;
    padding-top: 1.6rem;
  }

  .project-content .model-build-block {
    margin-top: 0.65rem;
    padding: 1.2rem 1.1rem 1.3rem;
    border-radius: 0.9rem;
    background: #e7e3db;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .project-content .model-build-block > * + * {
    margin-top: 1rem;
  }

  .project-content .model-build-block .model-contact-sheet + .model-slideshow {
    margin-top: 0.45rem;
  }

  .project-content .model-block-title {
    margin: 0;
    text-align: center;
    font-size: clamp(1.1rem, 1.35vw, 1.28rem);
    font-weight: 700;
    text-transform: none;
  }

  .project-content .model-block-copy {
    margin-top: 0;
    text-align: center;
    color: #52525b;
  }

  .project-content .model-block-focus {
    margin-top: 0;
    text-align: center;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    color: #18181b;
  }

  .project-content .model-slide {
    display: none;
    margin: 0;
  }

  .project-content .model-slide.is-active {
    display: block;
  }

  .project-content .model-slide .project-image-frame {
    margin: 0;
  }

  .project-content .model-slide-thumbs {
    margin-top: 0.75rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-content .model-slide-thumb {
    width: 56px;
    height: 56px;
    border: 1px solid rgba(0, 0, 0, 0.14);
    border-radius: 999px;
    overflow: hidden;
    background: #fff;
    cursor: pointer;
    padding: 0;
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .project-content .model-slide-thumb:hover {
    border-color: rgba(0, 0, 0, 0.45);
    transform: translateY(-1px);
  }

  .project-content .model-slide-thumb.is-active {
    border-color: rgba(0, 0, 0, 0.65);
  }

  .project-content .model-slide-thumb img {
    margin: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 999px;
  }

  .project-content .model-contact-sheet {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0;
    padding: 2rem 0.9rem 1.2rem;
    min-height: 170px;
    background: transparent;
    border: 0;
  }

  .project-content .model-contact-sheet::before,
  .project-content .model-slideshow::before {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.63rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(24, 24, 27, 0.52);
    white-space: nowrap;
  }

  .project-content .model-contact-sheet::before {
    content: "Fabrication Progress";
  }

  .project-content .model-slideshow::before {
    content: "Final Direction";
  }

  .project-content .model-contact-sheet .project-image-frame {
    --dock-scale: 1;
    flex: 0 0 auto;
    width: calc(94px * var(--dock-scale));
    margin: 0;
    border-radius: 0.5rem;
    cursor: pointer;
    will-change: width;
    transition: width 220ms cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 220ms ease;
  }

  .project-content .model-contact-sheet .project-image-frame img {
    width: 100%;
    height: calc(72px * var(--dock-scale));
    object-fit: cover;
    transition: height 220ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .project-content .model-contact-sheet .project-image-bar {
    display: none;
  }

  @keyframes filmstrip-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-1 * var(--filmstrip-distance, 0px)));
    }
  }

  .project-lightbox {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.86);
    cursor: zoom-out;
  }

  .project-lightbox.is-open {
    display: flex;
  }

  .project-lightbox img {
    display: block;
    max-width: min(94vw, 1600px);
    max-height: 90vh;
    width: auto;
    height: auto;
    border-radius: 0.75rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
  }

  @media (max-width: 960px) {
    .project-content .concept-split {
      grid-template-columns: 1fr;
    }

    .project-content .concept-copy {
      border-left: 0;
      border-top: 1px solid rgba(0, 0, 0, 0.14);
      padding-left: 0;
      padding-top: 1rem;
    }

    .project-content .model-horizontal .project-image-frame {
      flex-basis: min(78vw, 300px);
    }

    .project-content .model-horizontal .project-image-frame img {
      height: 156px;
    }

    .project-content .model-contact-sheet .project-image-frame img {
      height: calc(64px * var(--dock-scale));
    }

    .project-shell {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .project-toc {
      display: none;
    }

    .project-meta-strip {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }
  }
</style>

<script>
  (() => {
    const init = () => {
      const content = document.querySelector(".project-content");
      if (!content) return;

      const slugify = (value) =>
        value
          .toLowerCase()
          .trim()
          .replace(/[^\w\s-]/g, "")
          .replace(/\s+/g, "-");

      const buildToc = () => {
        const tocList = document.querySelector("[data-project-toc]");
        if (!tocList) return;

        const headings = Array.from(content.querySelectorAll("h2, h3")).filter((h) =>
          h.textContent?.trim()
        );
        if (!headings.length) return;

        const seen = new Map();
        headings.forEach((heading) => {
          if (!heading.id) {
            const base = slugify(heading.textContent || "section");
            const count = seen.get(base) || 0;
            const nextCount = count + 1;
            seen.set(base, nextCount);
            heading.id = nextCount > 1 ? `${base}-${nextCount}` : base;
          }
        });

        const sections = [];
        let currentSection = null;
        headings.forEach((heading) => {
          if (heading.tagName === "H2") {
            currentSection = { heading, children: [] };
            sections.push(currentSection);
            return;
          }
          if (!currentSection) {
            currentSection = { heading, children: [] };
            sections.push(currentSection);
            return;
          }
          currentSection.children.push(heading);
        });

        tocList.innerHTML = "";
        const sectionEntries = [];
        const allLinks = [];

        sections.forEach((section) => {
          const li = document.createElement("li");
          li.className = "toc-section";

          const topLink = document.createElement("a");
          topLink.href = `#${section.heading.id}`;
          topLink.textContent = section.heading.textContent?.trim() || "";
          li.appendChild(topLink);

          const subList = document.createElement("ul");
          subList.className = "project-toc-sublist";

          const childLinks = section.children.map((child) => {
            const childItem = document.createElement("li");
            const childLink = document.createElement("a");
            childLink.href = `#${child.id}`;
            childLink.textContent = child.textContent?.trim() || "";
            childItem.appendChild(childLink);
            subList.appendChild(childItem);
            allLinks.push(childLink);
            return childLink;
          });

          if (section.children.length) {
            li.appendChild(subList);
          }

          allLinks.push(topLink);
          tocList.appendChild(li);
          sectionEntries.push({ section, li, topLink, childLinks });
        });

        const headingToSectionId = new Map();
        sections.forEach((section) => {
          headingToSectionId.set(section.heading.id, section.heading.id);
          section.children.forEach((child) => {
            headingToSectionId.set(child.id, section.heading.id);
          });
        });

        const updateActiveToc = () => {
          const offset = 150;
          let current = headings[0];
          headings.forEach((heading) => {
            if (heading.getBoundingClientRect().top - offset <= 0) {
              current = heading;
            }
          });

          const currentId = current?.id;
          const activeSectionId = headingToSectionId.get(currentId);

          allLinks.forEach((link) => {
            link.classList.toggle("is-active", link.getAttribute("href") === `#${currentId}`);
          });

          sectionEntries.forEach((entry) => {
            const isActiveSection = entry.section.heading.id === activeSectionId;
            entry.li.classList.toggle("is-expanded", isActiveSection);
            entry.topLink.classList.toggle(
              "is-active",
              isActiveSection || entry.topLink.getAttribute("href") === `#${currentId}`
            );

            const subList = entry.li.querySelector(".project-toc-sublist");
            if (!subList) return;
            subList.style.maxHeight = isActiveSection ? `${subList.scrollHeight}px` : "0px";
          });
        };

        window.addEventListener("scroll", updateActiveToc, { passive: true });
        window.addEventListener("resize", updateActiveToc);
        updateActiveToc();
      };

      buildToc();

      const images = content.querySelectorAll("p > img");
      images.forEach((img) => {
        if (img.closest(".project-image-frame")) return;

        const label = img.getAttribute("alt")?.trim() || "Project visual";
        const frame = document.createElement("span");
        frame.className = "project-image-frame";

        const bar = document.createElement("span");
        bar.className = "project-image-bar";
        bar.textContent = label;

        img.replaceWith(frame);
        frame.appendChild(img);
        frame.appendChild(bar);
      });

      // Build markdown-authored concept sections into a 50/50 slideshow + bullet panel.
      const buildConceptSplits = () => {
        const conceptHeads = Array.from(content.querySelectorAll("h2, h3, h4, h5")).filter(
          (h) => h.textContent.trim().toLowerCase() === "concept development"
        );

        conceptHeads.forEach((heading) => {
          if (heading.dataset.splitBuilt === "true") return;

          let cursor = heading.nextElementSibling;
          const sectionNodes = [];
          while (cursor && !["H2", "H3"].includes(cursor.tagName)) {
            sectionNodes.push(cursor);
            cursor = cursor.nextElementSibling;
          }

          const conceptPara =
            heading.nextElementSibling && heading.nextElementSibling.tagName === "P"
              ? heading.nextElementSibling
              : null;

          // Markdown often places consecutive images in one paragraph; collect up to 3 from there.
          let conceptImages = conceptPara
            ? Array.from(conceptPara.querySelectorAll("img"))
            : [];

          if (conceptImages.length < 3) {
            const fallbackImgs = sectionNodes
              .filter((el) => el.tagName === "P")
              .flatMap((el) => Array.from(el.querySelectorAll("img")));
            conceptImages = fallbackImgs;
          }
          conceptImages = conceptImages.slice(0, 3);
          if (conceptImages.length < 2) return;

          const principlesHeading = sectionNodes.find(
            (el) =>
              ["H4", "H5"].includes(el.tagName) &&
              el.textContent.trim().toLowerCase() === "design principles"
          );
          if (!principlesHeading) return;

          let principlesList = null;
          let listCursor = principlesHeading.nextElementSibling;
          while (listCursor && !["H2", "H3", "H4", "H5"].includes(listCursor.tagName)) {
            if (listCursor.tagName === "UL") {
              principlesList = listCursor;
              break;
            }
            listCursor = listCursor.nextElementSibling;
          }
          if (!principlesList) return;

          const split = document.createElement("section");
          split.className = "concept-split";
          split.setAttribute("data-scroll-slider", "");

          const left = document.createElement("div");
          const sliderMain = document.createElement("div");
          sliderMain.className = "concept-slider-main";

          const thumbs = document.createElement("div");
          thumbs.className = "concept-thumbs";
          thumbs.setAttribute("role", "tablist");
          thumbs.setAttribute("aria-label", "Concept drawing slideshow");

          conceptImages.forEach((sourceImg, index) => {
            const src = sourceImg.getAttribute("src") || "";
            const alt = sourceImg.getAttribute("alt") || `Concept drawing ${index + 1}`;

            const slide = document.createElement("div");
            slide.className = `concept-slide${index === 0 ? " is-active" : ""}`;
            slide.setAttribute("data-slide", "");

            const frame = document.createElement("span");
            frame.className = "project-image-frame";

            const img = document.createElement("img");
            img.src = src;
            img.alt = alt;

            const bar = document.createElement("span");
            bar.className = "project-image-bar";
            bar.textContent = `Concept Drawing 0${index + 1}`;

            frame.appendChild(img);
            frame.appendChild(bar);
            slide.appendChild(frame);
            sliderMain.appendChild(slide);

            const thumb = document.createElement("button");
            thumb.type = "button";
            thumb.setAttribute("data-thumb", "");
            thumb.setAttribute("aria-label", `Show concept drawing ${index + 1}`);
            if (index === 0) thumb.className = "is-active";

            const thumbImg = document.createElement("img");
            thumbImg.src = src;
            thumbImg.alt = `Thumbnail for concept drawing ${index + 1}`;
            thumb.appendChild(thumbImg);
            thumbs.appendChild(thumb);
          });

          left.appendChild(sliderMain);
          left.appendChild(thumbs);

          const right = document.createElement("aside");
          right.className = "concept-copy";
          const rightHeading = document.createElement("h3");
          rightHeading.textContent = principlesHeading.textContent.trim();
          right.appendChild(rightHeading);
          right.appendChild(principlesList.cloneNode(true));

          split.appendChild(left);
          split.appendChild(right);

          // Keep intro text paragraph if present, but remove the image nodes from it.
          if (conceptPara) {
            conceptImages.forEach((img) => {
              const wrapper = img.closest(".project-image-frame");
              if (wrapper) wrapper.remove();
              else img.remove();
            });
            if (conceptPara.nextSibling) {
              conceptPara.parentNode?.insertBefore(split, conceptPara.nextSibling);
            } else {
              conceptPara.parentNode?.appendChild(split);
            }
          } else {
            heading.parentNode?.insertBefore(split, heading.nextSibling);
          }

          principlesHeading.remove();
          principlesList.remove();
          heading.dataset.splitBuilt = "true";
        });
      };

      buildConceptSplits();

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const sliders = content.querySelectorAll("[data-scroll-slider]");
      sliders.forEach((sliderRoot) => {
        const slides = Array.from(sliderRoot.querySelectorAll("[data-slide]"));
        const thumbs = Array.from(sliderRoot.querySelectorAll("[data-thumb]"));
        if (!slides.length || !thumbs.length || slides.length !== thumbs.length) return;

        let activeIndex = 0;
        let timer = null;
        let inView = false;

        const show = (index) => {
          activeIndex = index;
          slides.forEach((slide, i) => slide.classList.toggle("is-active", i === index));
          thumbs.forEach((thumb, i) => {
            thumb.classList.toggle("is-active", i === index);
            thumb.setAttribute("aria-selected", i === index ? "true" : "false");
          });
        };

        const stop = () => {
          if (!timer) return;
          window.clearInterval(timer);
          timer = null;
        };

        const start = () => {
          if (prefersReduced || timer || !inView) return;
          timer = window.setInterval(() => {
            if (activeIndex >= slides.length - 1) {
              stop();
              return;
            }
            show(activeIndex + 1);
          }, 1800);
        };

        thumbs.forEach((thumb, index) => {
          thumb.addEventListener("click", () => {
            show(index);
            stop();
            start();
          });
        });

        show(0);

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.target !== sliderRoot) return;
              inView = entry.isIntersecting && entry.intersectionRatio >= 0.45;
              if (inView) start();
              else stop();
            });
          },
          { threshold: [0.45, 0.75] }
        );
        observer.observe(sliderRoot);
      });

      const modelSlideshows = content.querySelectorAll("[data-model-slideshow]");
      modelSlideshows.forEach((root) => {
        const slides = Array.from(root.querySelectorAll(".model-slide"));
        const thumbsWrap = root.querySelector("[data-model-thumbs]");
        if (!slides.length || !thumbsWrap) return;

        let activeIndex = 0;

        const thumbs = slides.map((slide, index) => {
          const btn = document.createElement("button");
          btn.type = "button";
          btn.className = "model-slide-thumb";
          btn.setAttribute("aria-label", `Show final model slide ${index + 1}`);
          btn.addEventListener("click", () => {
            show(index);
          });

          const sourceImg = slide.querySelector("img");
          const thumbImg = document.createElement("img");
          thumbImg.src = sourceImg?.getAttribute("src") || "";
          thumbImg.alt = `Thumbnail ${index + 1}`;
          btn.appendChild(thumbImg);

          thumbsWrap.appendChild(btn);
          return btn;
        });

        const show = (index) => {
          activeIndex = Math.min(Math.max(index, 0), slides.length - 1);
          slides.forEach((slide, i) => slide.classList.toggle("is-active", i === activeIndex));
          thumbs.forEach((thumb, i) => thumb.classList.toggle("is-active", i === activeIndex));
        };

        show(0);
      });

      const horizontalCarousels = content.querySelectorAll(".model-horizontal");
      horizontalCarousels.forEach((carousel) => {
        if (carousel.dataset.filmstripBuilt === "true") return;
        const items = Array.from(carousel.querySelectorAll(":scope > .project-image-frame"));
        if (!items.length) return;

        const track = document.createElement("div");
        track.className = "filmstrip-track";

        items.forEach((item) => track.appendChild(item));
        items.forEach((item) => {
          const clone = item.cloneNode(true);
          clone.setAttribute("aria-hidden", "true");
          track.appendChild(clone);
        });

        carousel.innerHTML = "";
        carousel.appendChild(track);
        carousel.dataset.filmstripBuilt = "true";

        const updateFilmstripMetrics = () => {
          const distance = track.scrollWidth / 2;
          carousel.style.setProperty("--filmstrip-distance", `${distance}px`);
          const durationSeconds = Math.max(16, Math.round(distance / 70));
          carousel.style.setProperty("--filmstrip-duration", `${durationSeconds}s`);
        };

        updateFilmstripMetrics();
        if ("ResizeObserver" in window) {
          const ro = new ResizeObserver(updateFilmstripMetrics);
          ro.observe(carousel);
          ro.observe(track);
        } else {
          window.addEventListener("resize", updateFilmstripMetrics);
        }

        carousel.addEventListener("click", (event) => {
          const frame = event.target instanceof Element ? event.target.closest(".project-image-frame") : null;
          if (!frame || !carousel.contains(frame)) return;
          const img = frame.querySelector("img");
          if (!img) return;
          openLightbox(img.getAttribute("src") || "", img.getAttribute("alt") || "");
        });
      });

      const contactSheets = content.querySelectorAll(".model-contact-sheet");
      contactSheets.forEach((sheet) => {
        const frames = Array.from(sheet.querySelectorAll(".project-image-frame"));
        const resetDock = () => {
          frames.forEach((frame) => {
            frame.style.setProperty("--dock-scale", "1");
            frame.style.zIndex = "1";
            frame.style.boxShadow = "none";
          });
        };

        sheet.addEventListener("mousemove", (event) => {
          const pointerX = event.clientX;
          const maxDistance = 210;
          frames.forEach((frame) => {
            const rect = frame.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const distance = Math.abs(pointerX - centerX);
            const normalized = Math.min(distance / maxDistance, 1);
            const influence = Math.cos((normalized * Math.PI) / 2) ** 2;
            const scale = 1 + influence * 0.52;
            frame.style.setProperty("--dock-scale", scale.toFixed(3));
            frame.style.boxShadow =
              influence > 0.06 ? "0 8px 16px rgba(0, 0, 0, 0.14)" : "none";
          });
        });

        sheet.addEventListener("mouseleave", resetDock);
        resetDock();

        sheet.addEventListener("click", (event) => {
          const frame = event.target instanceof Element ? event.target.closest(".project-image-frame") : null;
          if (!frame || !sheet.contains(frame)) return;
          const img = frame.querySelector("img");
          if (!img) return;
          openLightbox(img.getAttribute("src") || "", img.getAttribute("alt") || "");
        });
      });

      const lightbox = document.createElement("div");
      lightbox.className = "project-lightbox";
      lightbox.setAttribute("aria-hidden", "true");
      lightbox.innerHTML = '<img alt="" />';
      const lightboxImg = lightbox.querySelector("img");
      document.body.appendChild(lightbox);

      const closeLightbox = () => {
        lightbox.classList.remove("is-open");
        lightbox.setAttribute("aria-hidden", "true");
        if (lightboxImg) {
          lightboxImg.setAttribute("src", "");
          lightboxImg.setAttribute("alt", "");
        }
      };

      const openLightbox = (src, alt) => {
        if (!src || !lightboxImg) return;
        lightboxImg.setAttribute("src", src);
        lightboxImg.setAttribute("alt", alt || "Expanded project image");
        lightbox.classList.add("is-open");
        lightbox.setAttribute("aria-hidden", "false");
      };

      lightbox.addEventListener("click", closeLightbox);
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeLightbox();
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  })();
</script>
