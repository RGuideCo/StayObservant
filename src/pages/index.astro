---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import ContactSection from "../components/ContactSection.astro";

const title = "Stay Observant";
---

<Layout title={title}>
  <Hero
    title="Stay Observant"
    note="Selected work below"
    primaryCtaText="View work"
    primaryCtaHref="#work"
    secondaryCtaText="Contact"
    secondaryCtaHref="#contact"
  />

  <!-- Cream wrapper for lower sections -->
  <div class="bg-[#F6F3ED] text-zinc-900">
    <ProjectsGrid />

    <div class="border-t border-black/10">
      <ContactSection />
    </div>
  </div>
</Layout>
